# Cloudflare Account Configuration
# Copy this file to .env and fill in your actual values

# Account ID (from https://dash.cloudflare.com - bottom right corner)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# API Token (create at https://dash.cloudflare.com/profile/api-tokens)
# Scopes needed: Account.Cloudflare Workers Tail Read, Account.R2, Account.KV
CLOUDFLARE_API_TOKEN=your_api_token_here

# Zone ID (from your domain settings, if you have one)
# Format: found in domain Overview page
CLOUDFLARE_ZONE_ID=your_zone_id_here

# Domain name (optional, for custom domain deployment)
CUSTOM_DOMAIN=analytics.yourdomain.com

# R2 Bucket Name
R2_BUCKET_NAME=cf-logs

# KV Namespace ID (will be generated during setup)
KV_NAMESPACE_ID=your_kv_id_here

# Environment
ENVIRONMENT=production
