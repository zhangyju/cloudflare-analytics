{
  "name": "cloudflare-analytics",
  "version": "1.0.0",
  "description": "Cloudflare日志分析与性能监控仪表板",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev",
    "build": "npm run build:workers && npm run build:pages",
    "build:workers": "esbuild src/workers/*.ts --bundle --outdir=dist/workers --platform=neutral --format=esm",
    "build:pages": "vite build",
    "deploy": "wrangler pages deploy dist",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "esbuild": "^0.19.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wrangler": "^3.12.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-query": "^3.39.0",
    "zustand": "^4.4.0",
    "echarts": "^5.4.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.292.0"
  }
}
